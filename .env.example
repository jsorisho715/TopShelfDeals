# Copy to .env and fill in. .env is gitignored.

# Telegram (created via @BotFather). Needed for M3+.
TELEGRAM_BOT_TOKEN=
# Your personal chat id (the only chat the bot will talk to). Get it from @userinfobot.
TELEGRAM_CHAT_ID=

# Scraping politeness. Stores are fetched SEQUENTIALLY (one at a time) with a
# random delay of SCRAPE_MIN..SCRAPE_MAX seconds between them.
SCRAPE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/131.0 Safari/537.36
SCRAPE_MIN_DELAY_SEC=2
SCRAPE_MAX_DELAY_SEC=5
# Reserved / not currently read by any code (scraping concurrency is fixed at 1).
SCRAPE_MAX_CONCURRENCY=2

# Default for the UI distance FILTER (miles) — NOT a scrape boundary. Every active
# store in app/seed/dispensaries.json is scraped regardless of distance; this only
# sets the dashboard's default Max-distance slider (1-25 mi). Widened to 20 to cover
# the Phoenix metro; snap the slider back to 7 anytime for a tight Scottsdale view.
RADIUS_MILES=20

# Reserved / not currently read by any code. The map anchors (Old Town, N. Scottsdale,
# Tempe, Midtown Phoenix) come from the "locations" array in dispensaries.json.
TARGET_ZIPS=85251,85255

# Timezone for all scheduling (Arizona does NOT observe DST)
TIMEZONE=America/Phoenix

# Reserved / not currently read by any code. Geocoding is hardcoded to the free
# OpenStreetMap Nominatim endpoint (<=1 req/s, cached to data/geocode_cache.json).
GEOCODE_PROVIDER=nominatim
GEOCODE_API_KEY=
